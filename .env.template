# ─── VideoBot Finanzas Claras — configuración ────────────────────────────────
# Copia este fichero a .env y rellena los valores reales
# NUNCA commitear .env a git

# ── LLM ──────────────────────────────────────────────────────────────────────
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5:14b
ANTHROPIC_API_KEY=sk-ant-...   # Fallback si Ollama falla

# ── Modelos IA ────────────────────────────────────────────────────────────────
FLUX_MODEL_ID=black-forest-labs/FLUX.1-schnell
FLUX_LOCAL_PATH=/home/YOUR_USER/models/flux-schnell
WAN2GP_DIR=/home/YOUR_USER/Wan2GP

# ── TTS ──────────────────────────────────────────────────────────────────────
TTS_VOICE=es
TTS_VOICE_SAMPLE=   # Opcional: ruta a audio de muestra para clonar la voz

# ── YouTube ───────────────────────────────────────────────────────────────────
CREDENTIALS_DIR=credentials
YT_CATEGORY_ID=28

# ── Pipeline ─────────────────────────────────────────────────────────────────
OUTPUT_DIR=output
DB_PATH=db/videobot.db
MAX_VIDEOS_PER_NIGHT=6
MUSIC_DEVICE=cpu       # cpu o cuda (usar cpu para no interferir con Wan2GP)
VIDEO_SOURCE=ai        # "ai" (FLUX + Ken Burns/Wan2.1) o "stock" (Pexels/Pixabay)
VIDEO_ENGINE=kenburns  # "kenburns" (rapido, FFmpeg) o "wan21" (IA, GPU, lento)

# ── Stock Footage (solo si VIDEO_SOURCE=stock) ──────────────────────────────
PEXELS_API_KEY=        # https://www.pexels.com/api/ (gratis, 200 req/hora)
PIXABAY_API_KEY=       # https://pixabay.com/api/docs/ (gratis, 100 req/min)

# ── Scheduler ────────────────────────────────────────────────────────────────
TZ=Europe/Madrid

# ═══════════════════════════════════════════════════════════════════════════════
# SaaS layer (only needed for API server, not for the CLI bot)
# ═══════════════════════════════════════════════════════════════════════════════

# ── Database (PostgreSQL) — host port 5438 ───────────────────────────────────
DATABASE_URL=postgresql+asyncpg://shortforge:shortforge@localhost:5438/shortforge

# ── Redis (Celery broker + rate limiter) — host port 6382 ───────────────────
REDIS_URL=redis://localhost:6382/0

# ── S3 / MinIO (video storage) — host port 9002 (console 9003) ─────────────
S3_ENDPOINT=http://localhost:9002
S3_BUCKET=shortforge-videos
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin

# ── Security ─────────────────────────────────────────────────────────────────
SECRET_KEY=change-me-in-production

# ── External API keys (SaaS providers) ──────────────────────────────────────
# ANTHROPIC_API_KEY already defined above
FAL_API_KEY=
KLING_API_KEY=
ELEVENLABS_API_KEY=

# ── Stripe (billing) ────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_STARTER=
STRIPE_PRICE_GROWTH=
STRIPE_PRICE_AGENCY=
